{
  "buildCommand": "",
  "installCommand": "",
  "env": {},
  "functions": {},
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "routes": [
    {
      "src": "/error-404",
      "status": 404,
      "destination": "/error-404.html"
    },
    {
      "src": "/error-500",
      "status": 500,
      "destination": "/error-500.html"
    },
    {
      "src": "/error-400",
      "status": 400,
      "destination": "/error-400.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
